{
    "hosting": {
        "public": "public",
        "ignore": [
            "firebase.json",
            "**/.*",
            "**/node_modules/**"
        ],
        "rewrites": [
            {
                "source": "/build/**",
                "destination": "/build/$1"
            },
            {
                "source": "/css/**",
                "destination": "/css/$1"
            },
            {
                "source": "/js/**",
                "destination": "/js/$1"
            },
            {
                "source": "/fonts/**",
                "destination": "/fonts/$1"
            },
            {
                "source": "**",
                "destination": "/index.php"
            }
        ]
    }
}
